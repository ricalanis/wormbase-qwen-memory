# --- Qwen Cloud (Alibaba Cloud Model Studio / DashScope) ---------------------
# Get a key: https://bailian.console.alibabacloud.com  (claim hackathon credits)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# International (Singapore) compatible-mode endpoint. For Mainland use:
#   https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_PLANNER_MODEL=qwen-plus

# --- Local small-Qwen triage worker (optional cameo, via Ollama) -------------
WBM_USE_LOCAL_QWEN=0
OLLAMA_BASE_URL=http://localhost:11434/v1
# ollama pull qwen3:1.7b   # then set WBM_USE_LOCAL_QWEN=1

# --- Storage -----------------------------------------------------------------
WBM_LEDGER_DB=./wbm_ledger.db
